# Copy this file to `keystore.properties` and fill in your real values.
# keystore.properties is git-ignored and must NEVER be committed.
#
# Generate the upload keystore first (see android/README.md), then point
# storeFile at it (path relative to the android/ project root, or absolute).

storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
